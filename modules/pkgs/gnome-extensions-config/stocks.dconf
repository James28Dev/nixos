# --- gnome stocks extension configuration ---
# commands:
# 1. find extension path: dconf list /org/gnome/shell/extensions/
# 2. dump current settings: dconf dump /org/gnome/shell/extensions/stocks/

[org/gnome/shell/extensions/stocks]
portfolios=''
position-in-panel='right'
refresh-interval=5
selected-portfolio='17f0b3cc6afa6699004c88c869f80003'
show-ticker-off-market-prices=false
ticker-display-variation='minimal'
ticker-interval=20
ticker-stock-amount=2
use-provider-instrument-names=true